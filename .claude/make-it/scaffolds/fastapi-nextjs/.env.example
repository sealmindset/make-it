# =============================================================================
# [APP_NAME] -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Placeholders (replaced during /make-it build phase):
#   [APP_NAME]          - human-readable app name
#   [APP_SLUG]          - kebab-case app name
#   [FRONTEND_PORT]     - host port for frontend (e.g., 3100)
#   [BACKEND_PORT]      - host port for backend (e.g., 8100)
#   [DB_PORT]           - host port for PostgreSQL (e.g., 5500)
#   [MOCK_OIDC_PORT]    - host port for mock-oidc (e.g., 10190)
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://[APP_SLUG]:[APP_SLUG]@localhost:[DB_PORT]/[APP_SLUG]

# ---------------------------------------------------------------------------
# OIDC Authentication
# ---------------------------------------------------------------------------
# For local development, these point to the mock-oidc container.
# For production, replace with your Azure AD / Entra ID values.
OIDC_ISSUER_URL=http://localhost:[MOCK_OIDC_PORT]
OIDC_CLIENT_ID=mock-oidc-client
OIDC_CLIENT_SECRET=mock-oidc-secret

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:[FRONTEND_PORT]
BACKEND_URL=http://localhost:[BACKEND_PORT]

# ---------------------------------------------------------------------------
# Additional Service URLs
# ---------------------------------------------------------------------------
# [ADDITIONAL_SERVICE_URLS]
# Uncomment and configure as needed for your integrations:
#
# JIRA_BASE_URL=http://localhost:8443
# JIRA_AUTH_TOKEN=mock-jira-token
#
# TEMPO_BASE_URL=http://localhost:8444
# TEMPO_AUTH_TOKEN=mock-tempo-token
