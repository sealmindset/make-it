# =============================================================================
# [APP_NAME] -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Placeholders (replaced during /make-it build phase):
#   [APP_NAME]          - human-readable app name
#   [APP_SLUG]          - kebab-case app name
#   [APP_PORT]          - host port for the app (e.g., 3100)
#   [DB_PORT]           - host port for PostgreSQL (e.g., 5500)
#   [MOCK_OIDC_PORT]    - host port for mock-oidc (e.g., 10190)
# =============================================================================

# ---------------------------------------------------------------------------
# Container Registry Proxy (auto-configured by /make-it if Zscaler detected)
# ---------------------------------------------------------------------------
# Routes Docker image pulls through a corporate ACR proxy cache to bypass
# SSL-inspecting proxies (Zscaler, Netskope, etc.). Leave empty to pull
# directly from public registries.
#
# Auto-discovered via: az acr list + az acr cache list
DOCKER_HUB_PREFIX=
MCR_PREFIX=
GHCR_PREFIX=

# ---------------------------------------------------------------------------
# Database (Prisma format)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://[APP_SLUG]:[APP_SLUG]@localhost:[DB_PORT]/[APP_SLUG]

# ---------------------------------------------------------------------------
# OIDC Authentication
# ---------------------------------------------------------------------------
# For local development, these point to the mock-oidc container.
# For production, replace with your identity provider values.
OIDC_ISSUER_URL=http://localhost:[MOCK_OIDC_PORT]
OIDC_CLIENT_ID=mock-oidc-client
OIDC_CLIENT_SECRET=mock-oidc-secret

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ---------------------------------------------------------------------------
# App URL
# ---------------------------------------------------------------------------
# Used for OIDC callback redirect and cookie Secure flag.
# Cookie Secure = true when this starts with "https://".
NEXTAUTH_URL=http://localhost:[APP_PORT]

# ---------------------------------------------------------------------------
# Secret Enforcement
# ---------------------------------------------------------------------------
# Set to "true" to make missing secrets fatal (recommended in Docker).
# Leave unset or "false" during next build (which evaluates modules at build time).
ENFORCE_SECRETS=true

# ---------------------------------------------------------------------------
# Additional Service URLs
# ---------------------------------------------------------------------------
# [ADDITIONAL_SERVICE_URLS]
# Uncomment and configure as needed for your integrations:
#
# JIRA_BASE_URL=http://localhost:8443
# JIRA_AUTH_TOKEN=mock-jira-token
