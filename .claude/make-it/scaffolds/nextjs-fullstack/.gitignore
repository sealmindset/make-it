# =============================================================================
# .gitignore -- Next.js Full-Stack application
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
.next/
out/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker volumes
# ---------------------------------------------------------------------------
postgres_data/

# ---------------------------------------------------------------------------
# Build
# ---------------------------------------------------------------------------
dist/
build/

# ---------------------------------------------------------------------------
# Test
# ---------------------------------------------------------------------------
coverage/

# ---------------------------------------------------------------------------
# Terraform (generated as DevOps handoff artifact)
# ---------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
npm-debug.log*

# ---------------------------------------------------------------------------
# Git worktrees (sibling checkouts created by scripts/worktree.sh)
# ---------------------------------------------------------------------------
*-worktrees/
.worktrees/

# ---------------------------------------------------------------------------
# Subagent-Driven Development scratch + ledger (.make-it/sdd/) -- recoverable from git log
# (note: .make-it/app-context.json IS committed; only the sdd/ subdir is ignored)
# ---------------------------------------------------------------------------
.make-it/sdd/
