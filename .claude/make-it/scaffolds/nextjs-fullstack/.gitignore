# =============================================================================
# .gitignore -- Next.js Full-Stack application
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
.next/
out/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker volumes
# ---------------------------------------------------------------------------
postgres_data/

# ---------------------------------------------------------------------------
# Build
# ---------------------------------------------------------------------------
dist/
build/

# ---------------------------------------------------------------------------
# Test
# ---------------------------------------------------------------------------
coverage/

# ---------------------------------------------------------------------------
# Terraform (generated as DevOps handoff artifact)
# ---------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
