# =============================================================================
# Dockerfile -- [APP_NAME] (Next.js Full-Stack)
# =============================================================================
# Generated by /make-it scaffold (nextjs-fullstack)
#
# Multi-stage build: deps -> builder -> runner
# Uses standalone output for minimal production image.
#
# Placeholders (replaced during /make-it build phase):
#   [APP_NAME]  - human-readable app name
# =============================================================================

# ---- Stage 1: Dependencies ----
ARG DOCKER_HUB_PREFIX=
FROM ${DOCKER_HUB_PREFIX}node:20-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json* ./
COPY prisma ./prisma/

RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# Generate Prisma client (needs schema at install time)
RUN npx prisma generate

# ---- Stage 2: Builder ----
ARG DOCKER_HUB_PREFIX=
FROM ${DOCKER_HUB_PREFIX}node:20-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Prisma client was generated in deps stage
# Re-generate in case schema changed
RUN npx prisma generate

# Ensure public dir exists (may be empty in scaffold)
RUN mkdir -p public

RUN npm run build

# ---- Stage 3: Runner ----
ARG DOCKER_HUB_PREFIX=
FROM ${DOCKER_HUB_PREFIX}node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy standalone output + static assets + public directory
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Copy Prisma files needed at runtime (migrations + schema for migrate deploy)
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /app/node_modules/@prisma ./node_modules/@prisma

# Copy entrypoint and seed
COPY --from=builder /app/entrypoint.sh ./entrypoint.sh
COPY --from=builder /app/prisma/seed.ts ./prisma/seed.ts
COPY --from=builder /app/package.json ./package.json

# Install only production deps needed for entrypoint (prisma CLI + tsx for seed)
RUN npm install --no-save prisma tsx

RUN chmod +x entrypoint.sh

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

ENTRYPOINT ["./entrypoint.sh"]
